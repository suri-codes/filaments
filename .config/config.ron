(
    directory: "./ZettelKasten",
    global_key_binds: {
        "ctrl-c": Quit,
        "ctrl-z": Suspend,
        "up": MoveUp,
        "down": MoveDown,
    },
    zk: (
        keybinds: {
            "<Ctrl-n>": NewZettel,
            "enter": OpenZettel,
        },
    ),
    todo: (
        keybinds: {
            "j": MoveDown,
            "k": MoveUp,
            // "<ctrl-d>": HalfPageDown,
        },
    ),
)
