(
    directory: "/Users/suri/dev/projects/filaments/ZettelKasten",
    global_key_binds: {
        "ctrl-z": Suspend,
        "up": MoveUp,
        "down": MoveDown,
        "ctrl-c": Quit,
    },
    zk: (
        keybinds: {
            "tab": SwitchTo(
                page: Todo(Explorer),
            ),
            "ctrl-n": NewZettel,
            "enter": OpenZettel,
        },
    ),
    todo: (
        explorer: (
            keybinds: {
                "tab": SwitchTo(
                    page: Zk,
                ),
                "3": SwitchTo(
                    page: Todo(TaskList),
                ),
                "g": NewSubGroup,
                "k": MoveUp,
                "2": SwitchTo(
                    page: Todo(Inspector),
                ),
                "j": MoveDown,
                "shift-g": NewGroup,
                "1": SwitchTo(
                    page: Todo(Explorer),
                ),
            },
        ),
        inspector: (
            keybinds: {
                "3": SwitchTo(
                    page: Todo(TaskList),
                ),
                "1": SwitchTo(
                    page: Todo(Explorer),
                ),
                "2": SwitchTo(
                    page: Todo(Inspector),
                ),
                "tab": SwitchTo(
                    page: Zk,
                ),
            },
        ),
        tasklist: (
            keybinds: {
                "k": MoveUp,
                "1": SwitchTo(
                    page: Todo(Explorer),
                ),
                "2": SwitchTo(
                    page: Todo(Inspector),
                ),
                "3": SwitchTo(
                    page: Todo(TaskList),
                ),
                "j": MoveDown,
                "tab": SwitchTo(
                    page: Zk,
                ),
            },
        ),
    ),
)